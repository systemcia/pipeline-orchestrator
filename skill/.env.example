# ============================================================
# Pipeline Orchestrator — 环境变量说明
# 复制本文件为 .env 并按需修改
# ============================================================

# ── 路径配置 ─────────────────────────────────────────────────

# 仓库根目录（自动探测，通常无需手动设置）
# PIPELINE_ORCHESTRATOR_HOME=/opt/pipeline-orchestrator

# Session 数据存储目录
# PIPELINE_SESSIONS_DIR=/opt/pipeline-orchestrator/sessions

# 效能分析/知识库数据库路径（默认 $PIPELINE_SESSIONS_DIR/pipeline.db）
# PIPELINE_DATA_DB=/opt/pipeline-orchestrator/sessions/pipeline.db

# 目标项目根目录（向上搜索 .pipeline-orchestrator.yaml 的起点）
# PIPELINE_PROJECT_ROOT=/path/to/your/project

# ── 管理台配置 ───────────────────────────────────────────────

# 后端端口（默认 18000）
# PIPELINE_SERVER_PORT=18000

# 前端开发端口（默认 18001）
# PIPELINE_WEB_PORT=18001

# 管理台 API 地址（Python 引擎调用，默认 http://localhost:18000/api）
# PIPELINE_API_BASE=http://localhost:18000/api

# CORS 白名单（逗号分隔，默认 http://localhost:18001）
# PIPELINE_CORS_ORIGINS=http://localhost:18001,http://127.0.0.1:18001

# 生产模式（启用后后端托管前端静态文件）
# NODE_ENV=production

# ── 编排行为 ─────────────────────────────────────────────────

# 当前项目 ID（list/trend/inject-rag 的默认过滤维度）
# PIPELINE_PROJECT=_default

# 严格测试证据模式（test-gate passed=true 时要求 shell_exit_code==0）
# PIPELINE_STRICT_TEST_EVIDENCE=0

# ── OpenSpec 集成（可选）────────────────────────────────────

# OpenSpec change 名称
# PIPELINE_OPENSPEC_CHANGE=

# OpenSpec 仓库根路径
# PIPELINE_OPENSPEC_REPO_ROOT=

# 并行策略（ownership | integrator）
# PIPELINE_PARALLEL_STRATEGY=
